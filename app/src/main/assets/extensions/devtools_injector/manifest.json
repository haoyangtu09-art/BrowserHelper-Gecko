{
  "manifest_version": 2,
  "name": "网络调试助手",
  "version": "1.1",
  "description": "网络抓包 / 拦截 / 替换 / Mock / 弱网 与控制台调试。",
  "browser_specific_settings": {
    "gecko": {
      "id": "netdebug@browserhelper.local"
    }
  },
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
  "permissions": [
    "mozillaAddons",
    "geckoViewAddons",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "storage",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "core/utils.js",
        "core/config.js",
        "core/proxy-feed.js",
        "interceptor/index.js",
        "breakpoint/index.js",
        "breakpoint/request.js",
        "breakpoint/response.js",
        "replace/rules.js",
        "panel/index.js",
        "panel/render.js",
        "panel/detail.js",
        "panel/toolbar.js",
        "extensions/loader.js",
        "extensions/presets/index.js",
        "extensions/presets/stream-hold.js",
        "extensions/index.js",
        "agent.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    "eruda.min.js"
  ]
}
