{
  "manifest_version": 2,
  "name": "DevTools Injector",
  "version": "2.0.0",
  "description": "Injects Eruda DevTools into the current page.",
  "browser_specific_settings": {
    "gecko": {
      "id": "devtools-injector@browserhelper.local"
    }
  },
  "permissions": [
    "mozillaAddons",
    "geckoViewAddons",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    "eruda.min.js"
  ]
}
