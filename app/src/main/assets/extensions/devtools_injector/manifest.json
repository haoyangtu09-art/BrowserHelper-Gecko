{
  "manifest_version": 2,
  "name": "DevTools Injector",
  "version": "2.0.0",
  "description": "Injects Eruda DevTools into the current page.",
  "browser_specific_settings": {
    "gecko": {
      "id": "devtools-injector@browserhelper.local"
    }
  },
  "permissions": [
    "mozillaAddons",
    "geckoViewAddons",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "storage",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "core/utils.js",
        "core/config.js",
        "replace/apply.js",
        "interceptor/fetch_page.js",
        "interceptor/xhr_page.js",
        "interceptor/xhr_isolated.js",
        "interceptor/fetch_isolated.js",
        "interceptor/index.js",
        "breakpoint/index.js",
        "breakpoint/request.js",
        "breakpoint/response.js",
        "replace/rules.js",
        "panel/index.js",
        "panel/render.js",
        "panel/detail.js",
        "panel/toolbar.js",
        "extensions/presets/index.js",
        "extensions/index.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    "eruda.min.js"
  ]
}
