{
  "manifest_version": 2,
  "name": "Cookie Export Helper",
  "version": "1.1.0",
  "description": "Exports cookies for the native browser helper.",
  "permissions": [
    "cookies",
    "<all_urls>",
    "nativeMessaging"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "applications": {
    "gecko": {
      "id": "cookie-export-helper-v2@videodownloader.local"
    }
  }
}
