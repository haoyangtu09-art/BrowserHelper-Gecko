{
  "manifest_version": 2,
  "name": "Cookie Export Helper",
  "version": "3.0.0",
  "description": "Exports cookies for the native browser helper.",
  "browser_specific_settings": {
    "gecko": {
      "id": "cookie-export-helper-v2@videodownloader.local"
    }
  },
  "permissions": [
    "mozillaAddons",
    "geckoViewAddons",
    "nativeMessaging",
    "cookies",
    "<all_urls>"
  ],
  "background": {
    "persistent": false,
    "scripts": [
      "background.js"
    ]
  }
}
